{
  "name": "orangepi-debug-tool",
  "version": "2.0.0",
  "description": "OrangePi Debug Tool - A comprehensive debugging utility for OrangePi devices",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "tauri:build:dev": "tauri build --config src-tauri/configs/tauri.dev.conf.json",
    "tauri:build:prod": "tauri build --config src-tauri/configs/tauri.prod.conf.json",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "lint:fix": "eslint . --ext ts,tsx --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css}\"",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "deps:check": "ncu",
    "deps:update": "ncu -u && npm install",
    "rust:check": "cd src-tauri && cargo check",
    "rust:fmt": "cd src-tauri && cargo fmt",
    "rust:clippy": "cd src-tauri && cargo clippy -- -D warnings",
    "rust:test": "cd src-tauri && cargo test",
    "rust:doc": "cd src-tauri && cargo doc --no-deps --open",
    "docs:gen": "typedoc --out docs/api src",
    "docs:serve": "http-server docs/api -p 8080",
    "release": "npm run lint && npm run typecheck && npm run test && npm run tauri:build",
    "postinstall": "cd src-tauri && cargo fetch"
  },
  "dependencies": {
    "@tauri-apps/api": "^1.5.3",
    "@tauri-apps/plugin-shell": "^1.0.0",
    "@tauri-apps/plugin-fs": "^1.0.0",
    "@tauri-apps/plugin-os": "^1.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "zustand": "^4.5.2",
    "react-router-dom": "^6.22.3",
    "@mui/material": "^5.15.14",
    "@mui/icons-material": "^5.15.14",
    "@emotion/react": "^11.11.4",
    "@emotion/styled": "^11.11.0",
    "@fontsource/roboto": "^5.0.12",
    "recharts": "^2.12.3",
    "react-virtualized": "^9.22.5",
    "date-fns": "^3.6.0",
    "lodash-es": "^4.17.21",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^1.5.11",
    "@types/react": "^18.2.67",
    "@types/react-dom": "^18.2.22",
    "@types/lodash-es": "^4.17.12",
    "@types/uuid": "^9.0.8",
    "@types/react-virtualized": "^9.21.29",
    "@typescript-eslint/eslint-plugin": "^7.3.1",
    "@typescript-eslint/parser": "^7.3.1",
    "@vitejs/plugin-react": "^4.2.1",
    "@vitest/coverage-v8": "^1.4.0",
    "@playwright/test": "^1.42.1",
    "autoprefixer": "^10.4.19",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.6",
    "postcss": "^8.4.38",
    "prettier": "^3.2.5",
    "typescript": "^5.4.3",
    "typedoc": "^0.25.12",
    "vite": "^5.2.0",
    "vitest": "^1.4.0",
    "jsdom": "^24.0.0",
    "@testing-library/react": "^14.2.2",
    "@testing-library/jest-dom": "^6.4.2",
    "@testing-library/user-event": "^14.5.2",
    "npm-check-updates": "^16.14.18",
    "http-server": "^14.1.1",
    "tailwindcss": "^3.4.1"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}